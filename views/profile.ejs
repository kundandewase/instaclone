<% include ./partials/header.ejs %>
<% const safeUsername = (user.username || '').replace(/\s+/g, ' ').trim(); %>
<% const safeName = (user.name || '').replace(/\s+/g, ' ').trim(); %>
<% const profileDisplayName = (safeName && safeName.toLowerCase().includes(safeUsername.toLowerCase())) ? safeName : [safeUsername, safeName].filter(Boolean).join(' '); %>
  <div class="w-full min-h-screen bg-black text-[#f5f5f5] pb-24">
    <div class="max-w-4xl mx-auto px-4 pt-4 sm:pt-6">
      <div class="sticky top-0 z-20 bg-black/90 backdrop-blur border-b border-[#262626] -mx-4 px-4 py-3 mb-5">
        <div class="flex justify-between items-center">
          <h3 class="text-lg font-semibold tracking-tight whitespace-nowrap overflow-hidden text-ellipsis"><%= profileDisplayName || safeUsername %></h3>
          <div class="icons flex gap-5 text-[#f5f5f5]">
            <a href="/upload" aria-label="Create"><i class="text-[1.35rem] ri-add-box-line"></i></a>
            <a href="/edit" aria-label="Settings"><i class="text-[1.35rem] ri-settings-3-line"></i></a>
          </div>
        </div>
      </div>

      <section class="rounded-2xl border border-[#262626] bg-gradient-to-b from-[#111111] to-[#090909] p-4 sm:p-6 shadow-[0_0_0_1px_rgba(255,255,255,0.02)]">
        <div class="flex items-center gap-4 sm:gap-6">
          <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full bg-gradient-to-tr from-fuchsia-600 via-rose-500 to-amber-400 p-[2px] shrink-0">
            <div class="w-full h-full rounded-full overflow-hidden border-2 border-black bg-black">
              <img class="w-full h-full object-cover" src="/images/uploads/<%= user.picture %>" alt="Profile">
            </div>
          </div>

          <div class="flex-1 min-w-0">
            <div class="grid grid-cols-3 gap-2 sm:gap-3">
              <div class="rounded-xl bg-[#171717] border border-[#2b2b2b] px-2 py-3 text-center">
                <h3 class="text-lg sm:text-xl font-semibold"><%= user.posts.length %></h3>
                <h4 class="text-[11px] sm:text-xs text-[#a3a3a3] uppercase tracking-wide mt-0.5">Posts</h4>
              </div>
              <div class="rounded-xl bg-[#171717] border border-[#2b2b2b] px-2 py-3 text-center">
                <h3 class="text-lg sm:text-xl font-semibold"><%= user.followers.length %></h3>
                <h4 class="text-[11px] sm:text-xs text-[#a3a3a3] uppercase tracking-wide mt-0.5">Followers</h4>
              </div>
              <div class="rounded-xl bg-[#171717] border border-[#2b2b2b] px-2 py-3 text-center">
                <h3 class="text-lg sm:text-xl font-semibold"><%= user.following.length %></h3>
                <h4 class="text-[11px] sm:text-xs text-[#a3a3a3] uppercase tracking-wide mt-0.5">Following</h4>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-5">
          <h3 class="text-base sm:text-lg font-semibold whitespace-nowrap overflow-hidden text-ellipsis"><%= profileDisplayName || safeUsername %></h3>
          <p class="text-xs text-[#7b7b7b] mt-0.5">@<%= safeUsername %></p>
          <p class="text-sm text-[#9ca3af] mt-1 leading-5"><%= user.bio ?? "You have not set anything yet, click edit profile to set it." %></p>
        </div>

        <div class="mt-5 flex gap-2 sm:gap-3">
          <a class="px-4 py-2.5 rounded-xl bg-white text-black text-sm font-semibold hover:bg-zinc-200 transition" href="/edit">Edit Profile</a>
          <a class="px-4 py-2.5 rounded-xl bg-[#222222] border border-[#333333] text-sm font-medium hover:bg-[#2b2b2b] transition" href="/upload">New Post</a>
        </div>
      </section>

      <section class="mt-6">
        <div class="flex items-center justify-between mb-3">
          <h4 class="text-sm uppercase tracking-[0.16em] text-[#9ca3af]">Posts</h4>
          <span class="text-xs text-[#6b7280]"><%= user.posts.length %> total</span>
        </div>

        <div class="posts grid grid-cols-3 gap-1.5 sm:gap-2">
          <% if(user.posts.length>0){ %>
            <% user.posts.slice().reverse().forEach(function(post){ %>
              <div class="post aspect-square rounded-lg overflow-hidden bg-[#111111] border border-[#262626]">
                <img class="w-full h-full object-cover" src="/images/uploads/<%= post.picture %>" alt="Post">
              </div>
            <% }) %>
          <% } else { %>
            <div class="col-span-3 rounded-2xl border border-dashed border-[#323232] min-h-[24vh] flex justify-center items-center">
              <small class="text-[#8b8b8b]">No posts yet.</small>
            </div>
          <% } %>
        </div>
      </section>
    </div>
  </div>
<% include ./partials/footer.ejs %>