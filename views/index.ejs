<% include ./partials/header.ejs %>
  <div class="w-full min-h-screen bg-[#fafafa] text-[#1f2937] py-8 px-4">
    <div class="max-w-5xl mx-auto min-h-[calc(100vh-4rem)] flex items-center justify-center gap-8 lg:gap-14">
      <div class="hidden lg:flex items-center justify-center w-[45%]">
        <div class="relative">
          <div class="absolute -inset-6 bg-gradient-to-br from-fuchsia-500/20 via-rose-500/15 to-amber-400/20 blur-3xl rounded-full"></div>
          <div class="relative w-[290px] h-[560px] bg-black rounded-[40px] p-2 shadow-2xl">
            <div class="w-full h-full rounded-[34px] overflow-hidden bg-white">
              <img class="w-full h-full object-cover" src="/images/logo.png" alt="Instagram style preview">
            </div>
          </div>
        </div>
      </div>

      <div class="w-full max-w-sm">
        <div class="bg-white border border-[#dbdbdb] rounded-md px-8 py-8 shadow-sm">
          <img class="w-40 mx-auto" src="/images/logo.png" alt="App logo">
          <p class="text-center text-sm text-zinc-500 mt-3 mb-5">Sign up to see photos and videos from your friends.</p>

          <form class="w-full" action="/register" method="post">
            <input class="px-3 py-2.5 border border-[#dbdbdb] rounded bg-[#fafafa] block w-full text-sm outline-none focus:border-zinc-400" type="text" placeholder="Username" name="username" required>
            <input class="px-3 py-2.5 border border-[#dbdbdb] rounded bg-[#fafafa] block w-full text-sm outline-none focus:border-zinc-400 mt-2" type="email" placeholder="Email" name="email" required>
            <input class="px-3 py-2.5 border border-[#dbdbdb] rounded bg-[#fafafa] block w-full text-sm outline-none focus:border-zinc-400 mt-2" type="text" placeholder="Full Name" name="name" required>
            <input class="px-3 py-2.5 border border-[#dbdbdb] rounded bg-[#fafafa] block w-full text-sm outline-none focus:border-zinc-400 mt-2" type="password" placeholder="Password" name="password" required>
            <input class="w-full bg-[#4cb5f9] hover:bg-[#3197e8] text-white font-semibold text-sm px-3 py-2.5 rounded mt-4 transition-colors" type="submit" value="Sign Up">
          </form>

          <p class="text-[11px] text-zinc-400 text-center mt-4 leading-4">By signing up, you agree to our Terms, Privacy Policy and Cookies Policy.</p>
        </div>

        <div class="bg-white border border-[#dbdbdb] rounded-md px-8 py-5 mt-3 text-center">
          <span class="text-sm text-zinc-600">Have an account? <a href="/login" class="text-[#0095f6] font-semibold">Log in</a></span>
        </div>

        <p class="text-center text-xs text-zinc-400 mt-6">Clone built for learning purposes</p>
      </div>
    </div>
  </div>
<% include ./partials/footer.ejs %>